generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model WaitTimeRecord {
  id         String   @id @default(uuid())
  rideId     Int
  rideName   String
  landName   String
  waitTime   Int
  isOpen     Boolean
  windowedAt DateTime
  recordedAt DateTime @default(now())

  @@unique([rideId, windowedAt])
  @@index([rideId, recordedAt])
  @@index([recordedAt])
}

model DailyForecast {
  id            String   @id @default(uuid())
  rideId        Int
  rideName      String
  landName      String
  forecastFor   DateTime
  predictedWait Int
  crowdScore    Int
  mlConfidence  Float
  createdAt     DateTime @default(now())

  @@unique([rideId, forecastFor])
  @@index([forecastFor])
}

// Stores per-date signals used to improve crowd score accuracy:
// Disney ticket tier, holiday/school-break flags, weather forecast, and Groq adjustment.
model DateContext {
  id              String    @id @default(uuid())
  date            DateTime  @unique // midnight UTC for the local park date
  tier            Int?      // Disney ticket tier 0–5 (higher = pricier/busier)
  isHoliday       Boolean   @default(false)
  isSchoolBreak   Boolean   @default(false)
  specialEvent    String?
  tierFetchedAt   DateTime? // when tier was last fetched; re-fetch after 24h
  tierSource      String?   // e.g. "disney-ticketing"
  groqDowEstimate Json?     // cached Map<dow, score> from estimateDowCrowdScores
  // Weather fields (Open-Meteo; climatological fallback beyond 16-day forecast window)
  tempHigh        Float?    // forecast high temperature in Fahrenheit
  tempLow         Float?    // forecast low temperature in Fahrenheit
  precipMm        Float?    // total precipitation in mm
  isRainy         Boolean?  // true when precipMm >= 2.5
  weatherFetchedAt DateTime? // when weather was last fetched
  // Groq post-process adjustment applied on top of XGBoost crowd score
  groqAdjustment  Float?    // points to add to mlCrowdScore (bounded ±35)
  groqReasoning   String?   // one-sentence explanation from Groq
  groqAdjustedAt  DateTime? // when groqAdjustment was last computed; re-sync after 7 days

  predictions     Prediction[]

  @@index([date])
}

// Accuracy join table: maps a historical prediction to actual wait for a given date.
model Prediction {
  id              String      @id @default(uuid())
  rideId          Int
  rideName        String
  predictedFor    DateTime
  predictedWait   Int
  actualWait      Int?        // filled in after the day passes
  dateContextId   String?
  dateContext     DateContext? @relation(fields: [dateContextId], references: [id])
  createdAt       DateTime    @default(now())

  @@index([rideId, predictedFor])
  @@index([dateContextId])
}

model CollectRun {
  id           String   @id @default(uuid())
  ranAt        DateTime @default(now())
  rowsUpserted Int
  success      Boolean
  errorMessage String?
}

// Hourly aggregates of WaitTimeRecord after the 30-day raw retention window.
// Each row = one hour of data for one ride on one day.
// Used as training data for the ML model alongside the raw 30-day window.
model HourlyWaitSummary {
  id          String   @id @default(uuid())
  rideId      Int
  rideName    String
  landName    String
  date        DateTime // midnight UTC of the park date
  hour        Int      // 0–23
  avgWait     Float
  peakWait    Int
  sampleCount Int
  isOpen      Boolean

  @@unique([rideId, date, hour])
  @@index([rideId, date])
  @@index([date])
}
